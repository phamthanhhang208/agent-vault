# ============================================
# AgentVault — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Auth0 Universal Login (Dashboard Auth) ---
AUTH0_SECRET=                    # openssl rand -hex 32
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=           # https://your-tenant.auth0.com
AUTH0_CLIENT_ID=                 # Regular Web App client ID
AUTH0_CLIENT_SECRET=             # Regular Web App client secret

# --- Auth0 Token Vault + CIBA ---
# May use same tenant, potentially different client for M2M
AUTH0_DOMAIN=                    # your-tenant.auth0.com (no https://)
AUTH0_TV_CLIENT_ID=              # Token Vault / M2M client ID
AUTH0_TV_CLIENT_SECRET=          # Token Vault / M2M client secret

# --- Vercel KV ---
KV_URL=                          # redis://...
KV_REST_API_URL=                 # https://...
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
